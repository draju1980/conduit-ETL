{
  "name": "@conduit/etl",
  "version": "0.1.0",
  "exports": {
    ".": "./mod.ts",
    "./cli": "./main.ts"
  },
  "publish": {
    "exclude": [
      "node_modules/",
      "tests/",
      "dist/",
      ".github/",
      "examples/",
      "cov_profile/",
      "pipeline.yaml",
      "*.md",
      "Makefile",
      "deno.lock"
    ]
  },
  "tasks": {
    "dev": "deno run -A main.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-net --allow-sys tests/ts/",
    "test:cov": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-net --allow-sys --coverage=cov_profile tests/ts/ && deno coverage cov_profile",
    "test:watch": "deno test --allow-read --allow-write --allow-env --allow-ffi --allow-net --allow-sys --watch tests/ts/",
    "lint": "deno lint src/ts/ tests/ts/ main.ts",
    "fmt": "deno fmt src/ts/ tests/ts/ main.ts",
    "check": "deno check main.ts",
    "publish:dry": "deno publish --dry-run --allow-slow-types --allow-dirty",
    "publish": "deno publish --allow-slow-types"
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/csv": "jsr:@std/csv@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/log": "jsr:@std/log@^0",
    "@cliffy/command": "jsr:@cliffy/command@^1",
    "zod": "npm:zod@^3.23",
    "@duckdb/node-api": "npm:@duckdb/node-api@1.5.1-r.1",
    "postgres": "npm:postgres@^3",
    "mysql": "npm:mysql2@^3/promise",
    "snowflake-sdk": "npm:snowflake-sdk@^1",
    "@google-cloud/bigquery": "npm:@google-cloud/bigquery@^7",
    "mongodb": "npm:mongodb@^6",
    "@aws-sdk/client-s3": "npm:@aws-sdk/client-s3@^3",
    "@aws-sdk/lib-storage": "npm:@aws-sdk/lib-storage@^3"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
